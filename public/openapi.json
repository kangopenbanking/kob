{
  "openapi": "3.1.0",
  "info": {
    "title": "Kang Open Banking API",
    "version": "2.1.0",
    "description": "COBAC-compliant Open Banking API for Cameroon and the CEMAC region. Enables account information (AISP), payment initiation (PISP), refunds, credit scoring, mobile money integration (MTN, Orange), virtual cards, settlements, disputes, transaction exports, risk management, audit trails, ISO 20022 messaging, payment links, recurring subscriptions, split payments, customer tokenization, and charge event timelines. Full dynamic specification available at the x-full-spec-url below.",
    "x-full-spec-url": "https://api.kangopenbanking.com/functions/v1/public-api-spec",
    "contact": {
      "name": "Kang Open Banking Developer Support",
      "email": "developers@kangopenbanking.com",
      "url": "https://kangopenbanking.com/developer"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://kangopenbanking.com/terms"
    }
  },
  "servers": [
    {
      "url": "https://api.kangopenbanking.com/v1",
      "description": "Production"
    },
    {
      "url": "https://api.kangopenbanking.com/v1",
      "description": "Sandbox (use sandbox API keys)",
      "x-environment": "sandbox"
    }
  ],
  "security": [
    { "oauth2": ["accounts", "payments"] },
    { "bearerAuth": [] }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "API Health Check",
        "operationId": "getHealth",
        "tags": ["System"],
        "security": [],
        "responses": {
          "200": { "description": "API is healthy" }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "summary": "Request Access Token",
        "operationId": "createToken",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": { "type": "string", "enum": ["client_credentials", "authorization_code"] },
                  "client_id": { "type": "string" },
                  "client_secret": { "type": "string" }
                },
                "required": ["grant_type", "client_id", "client_secret"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Access token issued" }
        }
      }
    },
    "/aisp/accounts": {
      "get": {
        "summary": "List Accounts",
        "operationId": "listAccounts",
