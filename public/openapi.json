          { "name": "Idempotency-Key", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "merchant_id": { "type": "string", "format": "uuid" },
                  "name": { "type": "string" },
                  "amount": { "type": "number" },
                  "currency": { "type": "string", "default": "XAF" },
                  "interval": { "type": "string", "enum": ["daily", "weekly", "monthly", "yearly"] },
                  "interval_count": { "type": "integer", "default": 1 },
                  "duration": { "type": "integer" }
                },
                "required": ["merchant_id", "name", "amount"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment plan created" }
