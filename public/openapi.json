    "/gateway/payment-links": {
      "post": {
        "summary": "Create Payment Link",
        "operationId": "createPaymentLink",
        "tags": ["Payment Links"],
        "parameters": [
          { "name": "Idempotency-Key", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "merchant_id": { "type": "string", "format": "uuid" },
                  "title": { "type": "string" },
                  "amount": { "type": "number" },
                  "currency": { "type": "string", "default": "XAF" },
                  "description": { "type": "string" },
                  "redirect_url": { "type": "string", "format": "uri" },
                  "max_uses": { "type": "integer" },
                  "expires_at": { "type": "string", "format": "date-time" }
                },
                "required": ["merchant_id", "title", "amount"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment link created" }
        }
      },
      "get": {
        "summary": "List Payment Links",
        "operationId": "listPaymentLinks",
        "tags": ["Payment Links"],
        "parameters": [
          { "name": "merchant_id", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of payment links" }
        }
      }
    },
    "/gateway/payment-links/{slug}": {
      "get": {
        "summary": "Get Payment Link",
        "operationId": "getPaymentLink",
        "tags": ["Payment Links"],
        "security": [],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Payment link details" }
        }
      }
    },
    "/gateway/payment-plans": {
      "post": {
        "summary": "Create Payment Plan",
        "operationId": "createPaymentPlan",
        "tags": ["Subscriptions"],
