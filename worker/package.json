{
  "name": "kob-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker that fronts api.kangopenbanking.com and proxies to the Supabase Edge Functions origin.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local=false",
    "dev:local": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "deploy:verified": "wrangler deploy && ./scripts/verify-deploy.sh",
    "verify": "./scripts/verify-deploy.sh",
    "tail": "wrangler tail",
    "test": "vitest run",
    "test:smoke": "bash ./scripts/test-local.sh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.78.0"
  }
}
